<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reel Counter"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/openSettingsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open Accessibility Settings" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerHorizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/debounceLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="Debounce: 0.6s" />

        <SeekBar
            android:id="@+id/debounceSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="19"
            android:progress="0"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Max one count every N seconds. Range 0.5s – 10s."
            android:textSize="12sp"
            android:paddingBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerHorizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Diagnostic mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <Switch
                android:id="@+id/diagnosticSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnostic logging (adb logcat -s ReelCounter)"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn on, open Instagram, swipe a few Reels, then run:\nadb logcat -s ReelCounter\nto see what className/dy values actually arrive."
            android:textSize="12sp"
            android:paddingBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerHorizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Today" android:textSize="16sp" />
        <TextView android:id="@+id/todayCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="40sp" android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="This week" android:textSize="16sp" />
        <TextView android:id="@+id/weekCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="32sp"
            android:paddingBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="This month" android:textSize="16sp" />
        <TextView android:id="@+id/monthCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="32sp"
            android:paddingBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="This year" android:textSize="16sp" />
        <TextView android:id="@+id/yearCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="32sp"
            android:paddingBottom="24dp" />

        <Button
            android:id="@+id/refreshBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh" />
    </LinearLayout>
</ScrollView>
